<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>

<GridPane hgap="5" vgap="5"
          xmlns="http://javafx.com/javafx/25"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.example.calculatorprogram.CalculatorController">

    <TextField fx:id="display"
               GridPane.columnIndex="0"
               GridPane.rowIndex="0"
               GridPane.columnSpan="4" />

    <Button text="7" onAction="#handleNumber" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
    <Button text="8" onAction="#handleNumber" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
    <Button text="9" onAction="#handleNumber" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
    <Button text="/" onAction="#handleOperator" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

    <Button text="4" onAction="#handleNumber" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
    <Button text="5" onAction="#handleNumber" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    <Button text="6" onAction="#handleNumber" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
    <Button text="*" onAction="#handleOperator" GridPane.columnIndex="3" GridPane.rowIndex="2"/>

    <Button text="1" onAction="#handleNumber" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
    <Button text="2" onAction="#handleNumber" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
    <Button text="3" onAction="#handleNumber" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
    <Button text="-" onAction="#handleOperator" GridPane.columnIndex="3" GridPane.rowIndex="3"/>

    <Button text="0" onAction="#handleNumber" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
    <Button text="." onAction="#handleNumber" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
    <Button text="=" onAction="#handleEqual" GridPane.columnIndex="2" GridPane.rowIndex="4"/>
    <Button text="+" onAction="#handleOperator" GridPane.columnIndex="3" GridPane.rowIndex="4"/>

</GridPane>